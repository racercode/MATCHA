# Claude API
ANTHROPIC_API_KEY=

# Claude Managed Agents — run `npx tsx src/agents/setup.ts --init` to generate these
MANAGED_ENV_ID=
PERSONA_AGENT_ID=
COFFEE_AGENT_ID=

# Firebase Admin SDK (download from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_REALTIME_DB_URL=

# Upstash Redis — use the "Redis URL" from Upstash Console (format: rediss://default:<token>@<host>:6380)
UPSTASH_REDIS_URL=

# Gov Agent Pipeline
GOV_AGENT_CONCURRENCY=1   # 1=sequential (safe default), >1=parallel resource agents

# Server
PORT=3000
NODE_ENV=development
